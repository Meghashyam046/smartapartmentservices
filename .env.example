

# APP_URL: The URL where this applet is hosted.
# automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_CLIENT_ID: Optional. Google OAuth Client ID for real Google Sign-In.
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: Optional. Google OAuth Client Secret for real Google Sign-In.
GOOGLE_CLIENT_SECRET=

JWT_SECRET=my_super_secret_key_123
